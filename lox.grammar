// Here we show the context free grammar of the Lox language

expression -> literal
            | unary
	    | binary
	    | grouping;

literal    -> NUMBER | STRING | "true" | "false" | "nil";
grouping   -> "(" expression ")";
unary      -> ( "-" | "!" ) expression;
binary     -> expression operator expression
operator   -> "==" | "!=" | "<" | "<=" | ">" | ">="
	    | "+" | "-" | "*" | "/";  
