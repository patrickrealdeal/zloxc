if (5 == 5) {
  print "hello from IF";
} else {
  print "NOPE!";
}

var i = 0;
while (i < 3) {
  print "while";
  i = i + 1;
}

var j;
for (j = 0; j < 3; j = j + 1) {
   print "for";
}

fun hello(a,b,c) {
  return a + b - c;
}

fun hello_(name) {
  print "hello " + name;
}

fun sum(a, b, c) {
  return a + b + c;
}

print 4 + sum(5, 6, 7);

print hello(1,2,4);
hello_("Jean");
